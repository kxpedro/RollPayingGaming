@page
@model RollPayingGaming.Pages.RoletaModel
@{
    ViewData["Title"] = "Roleta";
}
<h1 style="color: white;text-align: center;color: white;padding: 15px;">RPG - Roll Paying Game</h1>
<div style="display: flex; align-items: center; gap: 24px;">
    <h3 style="margin-bottom: 0;color: white">Sorteie a raça do seu personagem</h3>
    <button id="novo-jogo-btn" style="margin-left: auto; background: #ffe082; border: none; border-radius: 6px; padding: 8px 18px; font-weight: bold; cursor: pointer; box-shadow: 0 1px 4px rgba(0,0,0,0.07);">Novo Jogo</button>
</div>
<div style="display: flex; flex-direction: row; justify-content: center; align-items: stretch; gap: 40px; margin-top: 30px; min-height: 500px;">

    <!-- Coluna lateral esquerda: Equipamentos e Inventário -->
    <div style="display: flex; flex-direction: column; align-items: center; gap: 24px;">
        <div id="equipamentos" style="width: 380px; background: #f3f6fa; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 18px 14px; display: flex; flex-direction: column; align-items: center;">
            <h4 style="margin-top:0;">Equipamentos</h4>
            <ul id="equipamentos-list" style="list-style: none; padding: 0; width: 100%;"></ul>
        </div>
        <div id="inventario" style="width: 380px; background: #f3f6fa; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 18px 14px; display: flex; flex-direction: column; align-items: center;">
            <h4 style="margin-top:0;">Inventário</h4>
            <ul id="inventario-list" style="list-style: none; padding: 0; width: 100%;"></ul>
        </div>
        <div id="log-container" style="width: 380px; max-height: 180px; overflow-y: auto; background: #f8f9fa; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 12px 10px; margin-top: 30px;">
            <h4 style="margin-top:0; font-size:1em;">Logs</h4>
            <ul id="log-list" style="list-style: decimal inside; padding-left: 0; margin-bottom: 0;"></ul>
        </div>
    </div>

    <!-- Roleta central -->
    <div style="display: flex; flex-direction: column; align-items: center; min-width: 420px; flex: 1;">
        <canvas id="roleta-canvas" width="400" height="400" style="border:1px solid #ccc;"></canvas>
        <button id="girar-btn" style="margin-top: 20px;">Girar</button>
        <div id="resultado" style="margin-top: 20px; font-size: 1.2em;color: white"></div>
        <!-- Popup de resultado -->
        <div id="popup-resultado" style="display:none; position: fixed; left:0; top:0; width:100vw; height:100vh; background:rgba(0,0,0,0.45); z-index:1000; align-items:center; justify-content:center;">
            <div style="background:#fffbe6; border-radius:14px; box-shadow:0 4px 24px rgba(0,0,0,0.18); padding:38px 32px; min-width:320px; max-width:90vw; text-align:center; position:relative;">
                <div id="popup-resultado-conteudo" style="font-size:1.2em; color:#222; margin-bottom:24px;"></div>
                <button id="fechar-popup-btn" style="background:#ffe082; border:none; border-radius:6px; padding:10px 28px; font-weight:bold; font-size:1.1em; cursor:pointer; box-shadow:0 1px 4px rgba(0,0,0,0.07);">OK</button>
            </div>
        </div>
        <button id="proximo-btn" style="margin-top: 20px; display:none;">Próximo</button>

    </div>

    <!-- Ficha do Personagem -->
    <div id="ficha" style="width: 380px; background: #fffbe6; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.10); padding: 22px 18px; display: flex; flex-direction: column; align-items: flex-start; margin-left: 10px;">
        <h4 style="margin-top:0;">Ficha do Personagem</h4>
        <div id="ficha-content" style="font-size: 1.05em;"></div>
    </div>
</div>

@section Scripts {

    <!-- Efeito sonoro da roleta -->
    <audio id="audio-tick" src="/audio/tick.mp3" preload="auto"></audio>
    <script>

        // Função centralizada para animar a roleta de sucesso/falha/crítico
        function animarRoletaSucesso(anguloFinal, opcoesSucesso, fatiasSucesso, sorteadoIdx, chance, encontroAtual, callback) {
            if (!encontroAtual) {
                if (typeof callback === 'function') callback();
                return;
            }
            let duracao = 4200; // Mais dramático!
            const anguloInicial = anguloAtual;
            const start = performance.now();
            const audioTick = document.getElementById('audio-tick');
            let ultimoTick = 0;
            let tickInterval = 120;
            function playTick() {
                if (audioTick) {
                    audioTick.currentTime = 0;
                    audioTick.play();
                }
            }
            function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }
            function anim(now) {
                const elapsed = now - start;
                let t = Math.min(1, elapsed / duracao);
                t = easeOutCubic(t);
                anguloAtual = anguloInicial + (anguloFinal - anguloInicial) * t;
                desenharRoleta(anguloAtual, opcoesSucesso, fatiasSucesso);
                if (elapsed - ultimoTick > tickInterval) {
                    playTick();
                    ultimoTick = elapsed;
                }
                if (elapsed < duracao) {
                    requestAnimationFrame(anim);
                } else {
                    anguloAtual = anguloFinal;
                    desenharRoleta(anguloFinal, opcoesSucesso, fatiasSucesso);
                    if (callback) callback();
                }
            }
            requestAnimationFrame(anim);
        }

        function getHP() {
            return Number(localStorage.getItem('rpg_hp') || '5');
        }
        function setHP(val) {
            localStorage.setItem('rpg_hp', val);
        }
        function resetHP() {
            setHP(5);
        }

        function getDefesa() {
            return Number(localStorage.getItem('rpg_defesa') || '0');
        }
        function setDefesa(val) {
            localStorage.setItem('rpg_defesa', val);
        }
        function getXP() {
            return Number(localStorage.getItem('rpg_xp') || '0');
        }
        function setXP(val) {
            localStorage.setItem('rpg_xp', val);
        }
        function getLevel() {
            return Number(localStorage.getItem('rpg_level') || '1');
        }
        function setLevel(val) {
            localStorage.setItem('rpg_level', val);
        }
        function addXP(val) {
            let xp = getXP() + val;
            let level = getLevel();
            let subiuLevel = false;
            let levelsGanhos = 0;
            while (xp >= 100) {
                xp -= 100;
                level++;
                subiuLevel = true;
                levelsGanhos++;
            }
            setXP(xp);
            setLevel(level);
            if (subiuLevel) {
                // Aumenta +1 ponto base em todos os atributos por level ganho
                let baseKey = 'rpg_bonus_base_atributos';
                let bonusBase = JSON.parse(localStorage.getItem(baseKey) || '{}');
                let listaAtributos = ['forca','destreza','constituicao','inteligencia','sabedoria','carisma'];
                listaAtributos.forEach(attr => {
                    bonusBase[attr] = (bonusBase[attr] || 0) + levelsGanhos;
                });
                localStorage.setItem(baseKey, JSON.stringify(bonusBase));
                atualizarLog(`Você subiu para o nível ${level}! Todos os atributos base aumentaram em +${levelsGanhos}.`);
                renderFicha();
            }
        }
        
        let coracoes = getHP();
        let listaAtributos = ['forca','destreza','constituicao','inteligencia','sabedoria','carisma'];
        let starterAttrData = null;
        let encontroAtual = null;

        async function carregarStarterAttr() {
            if (!starterAttrData) {
                const resp = await fetch('/data/starterAttr.json');
                starterAttrData = await resp.json();
            }
        }

        // Exibe todos os atributos e perícias do jogador na ficha
        async function renderFicha() {
            await carregarStarterAttr();
            // Carregar dados de skills e starterSkills
            if (!window.skillsData) {
                window.skillsData = (await (await fetch('/data/skills.json')).json()).lista_pericias;
            }

            if (!window.starterSkillsData) {
                window.starterSkillsData = await (await fetch('/data/starterSkills.json')).json();
            }

            const skillsData = window.skillsData;
            const starterSkillsData = window.starterSkillsData;

            const hp = getHP();
            
            // Calcular defesa base e bônus de itens
            let defesaBase = 0;
            let defesaBonus = 0;

            // Defesa base pode ser expandida no futuro (ex: raça/classe)
            // Bônus de itens/equipamentos
            const inv = getInventario();
            const eqs = getEquipamentos();

            inv.forEach(item => {
                if (item.atributos && item.atributos.defesa) defesaBonus += item.atributos.defesa;
            });
            eqs.forEach(item => {
                if (item.atributos && item.atributos.defesa) defesaBonus += item.atributos.defesa;
            });
            const defesa = defesaBase + defesaBonus;
            const xp = getXP();
            const level = getLevel();
            const raca = localStorage.getItem('rpg_raca') || '-';
            const classe = localStorage.getItem('rpg_classe') || '-';
            const dadoVida = localStorage.getItem('rpg_dado_vida') || '-';

            let html = `<b>Raça:</b> ${raca}<br>`;
            html += `<b>Classe:</b> ${classe}<br>`;
            html += `<b>Dado de Vida:</b> ${dadoVida}<br>`;
            html += `<b>Pontos de Vida:</b> <span style='color:#d32f2f;'>${hp} / 5</span><br>`;
            html += `<b>Defesa:</b> <span style='color:#1976d2;'>${defesa}</span>`;
            if (defesaBonus > 0) html += ` <span style='color:#388e3c;'>(+${defesaBonus} itens)</span>`;
            html += '<br>';
            html += `<b>Experiência:</b> <span style='color:#6d4c41;'>${xp} / 100</span><br>`;
            html += `<b>Level:</b> <span style='color:#388e3c;'>${level}</span><br>`;

            // Inicializa objetos para base e bônus
            let atributosBase = {};
            let atributosBonus = {};
            let atributosTotais = {};
            listaAtributos.forEach(attr => {
                atributosBase[attr] = 0;
                atributosBonus[attr] = 0;
                atributosTotais[attr] = 0;
            });

            // Raça: atributos base
            if (starterAttrData && starterAttrData.templates_raciais && raca && raca !== '-') {
                const found = starterAttrData.templates_raciais.find(t => t.raca === raca);
                if (found && found.atributos) {
                    for (const [attr, val] of Object.entries(found.atributos)) {
                        const key = attr.toLowerCase();
                        if (listaAtributos.includes(key)) atributosBase[key] += val;
                    }
                }
            }
            // Raça: atributos base (caso não use starterAttrData)
            if (!starterAttrData && window.racesData && raca && raca !== '-') {
                const found = window.racesData.find(t => t.nome === raca);
                if (found && found.atributos) {
                    for (const [attr, val] of Object.entries(found.atributos)) {
                        const key = attr.toLowerCase();
                        if (listaAtributos.includes(key)) atributosBase[key] += val;
                    }
                }
            }
            // Classe: atributos base
            if (window.classesData && classe && classe !== '-') {
                const found = window.classesData.find(c => c.nome === classe);
                if (found && found.atributos) {
                    for (const [attr, val] of Object.entries(found.atributos)) {
                        const key = attr.toLowerCase();
                        if (listaAtributos.includes(key)) atributosBase[key] += val;
                    }
                }
            }
            // Bônus de level up
            let baseKey = 'rpg_bonus_base_atributos';
            let bonusBase = JSON.parse(localStorage.getItem(baseKey) || '{}');
            listaAtributos.forEach(attr => {
                if (bonusBase[attr]) atributosBase[attr] += bonusBase[attr];
            });

            // Soma bônus dos itens do inventário
            inv.forEach(item => {
                if (item.atributos) {
                    for (const [attr, val] of Object.entries(item.atributos)) {
                        const key = attr.toLowerCase();
                        if (listaAtributos.includes(key)) atributosBonus[key] += val;
                    }
                }
            });
            // Soma bônus dos equipamentos
            eqs.forEach(item => {
                if (item.atributos) {
                    for (const [attr, val] of Object.entries(item.atributos)) {
                        const key = attr.toLowerCase();
                        if (listaAtributos.includes(key)) atributosBonus[key] += val;
                    }
                }
            });
            // Soma total
            listaAtributos.forEach(attr => {
                atributosTotais[attr] = atributosBase[attr] + atributosBonus[attr];
            });
            // Exibir todos os atributos
            let atributosHtml = '<div style="margin-top:10px"><b>Atributos:</b><ul style="margin:0 0 0 18px;">';
            listaAtributos.forEach(attr => {
                let bonusStr = atributosBonus[attr] !== 0 ? ` <span style='color:#388e3c;'>(+${atributosBonus[attr]})</span>` : '';
                atributosHtml += `<li>${attr.charAt(0).toUpperCase() + attr.slice(1)}: <b>${atributosTotais[attr]}</b> <span style='color:#888;font-size:0.95em;'>(base: ${atributosBase[attr]})</span>${bonusStr}</li>`;
            });
            atributosHtml += '</ul></div>';


            // --- PERÍCIAS (todas, mesmo que 0) ---
            let pericias = {};
            // Inicializa todas as perícias com 0
            skillsData.forEach(skill => { pericias[skill.nome] = 0; });
            if (starterSkillsData && starterSkillsData.pericias_iniciais) {
                // Raça
                if (raca && raca !== '-') {
                    const foundRace = starterSkillsData.pericias_iniciais.races.find(r => r.nome === raca);
                    if (foundRace && foundRace.skills) {
                        for (const [nome, val] of Object.entries(foundRace.skills)) {
                            pericias[nome] = (pericias[nome] || 0) + val;
                        }
                    }
                }
                // Classe
                if (classe && classe !== '-') {
                    const foundClass = starterSkillsData.pericias_iniciais.classes.find(c => c.nome === classe);
                    if (foundClass && foundClass.skills) {
                        for (const [nome, val] of Object.entries(foundClass.skills)) {
                            pericias[nome] = (pericias[nome] || 0) + val;
                        }
                    }
                }
            }
            // Exibir todas as perícias
            let periciasHtml = '<div style="margin-top:10px"><b>Perícias:</b><ul style="margin:0 0 0 18px;">';
            skillsData
                .map(s => s.nome)
                .sort((a,b)=>a.localeCompare(b))
                .forEach(nome => {
                    const skillObj = skillsData.find(s => s.nome === nome);
                    const attrBase = skillObj ? skillObj.atributo_base : '-';
                    periciasHtml += `<li>${nome} <span style='color:#888'>(Base: ${attrBase})</span>: <b>${pericias[nome]}</b></li>`;
                });
            periciasHtml += '</ul></div>';

            html += atributosHtml + periciasHtml;
            document.getElementById('ficha-content').innerHTML = html;
        }

        // Atualizar ficha sempre que uma etapa for sorteada
        const oldAtualizarLog = atualizarLog;
        atualizarLog = function(resultado) {
            oldAtualizarLog(resultado);
            renderFicha();
        }
        // Renderizar ficha ao carregar a página
        renderFicha();
        // Botão Novo Jogo
        document.getElementById('novo-jogo-btn').onclick = function() {
            resetHP();
            setDefesa(0);
            setXP(0);
            setLevel(1);
            // Limpa localStorage dos dados do personagem
            localStorage.removeItem('rpg_raca');
            localStorage.removeItem('rpg_classe');
            localStorage.removeItem('rpg_dado_vida');
            localStorage.removeItem('rpg_starterpack');
            localStorage.removeItem('rpg_equipamentos');
            localStorage.removeItem('rpg_inventario');
            // Limpa logs
            if (window.logList) window.logList.length = 0;
            // Reinicia etapa
            etapaAtual = 0;
            anguloAtual = 0;
            renderEquipamentos();
            renderInventario();
            atualizarTitulo();
            desenharRoleta();
            document.getElementById('resultado').innerText = 'Gire a roleta para sortear!';
            document.getElementById('proximo-btn').style.display = 'none';
            renderFicha();
            // Limpa logs visuais
            const ul = document.getElementById('log-list');
            if (ul) ul.innerHTML = '';
        };

        // Carregar do localStorage ou inicializar vazio
        function getEquipamentos() {
            return JSON.parse(localStorage.getItem('rpg_equipamentos') || '[]');
        }
        function getInventario() {
            return JSON.parse(localStorage.getItem('rpg_inventario') || '[]');
        }
        function setEquipamentos(arr) {
            localStorage.setItem('rpg_equipamentos', JSON.stringify(arr));
        }
        function setInventario(arr) {
            localStorage.setItem('rpg_inventario', JSON.stringify(arr));
        }

        // Renderizar listas
        function renderEquipamentos() {
            const ul = document.getElementById('equipamentos-list');
            ul.innerHTML = '';
            const eqs = getEquipamentos();
            // Descobrir todos os slots presentes
            const slots = [
                'peitoral', 'arma1', 'arma2', 'escudo', 'artefato', 'instrumento'
            ];
            // Adiciona slots extras encontrados nos equipamentos
            eqs.forEach(e => {
                if (e.slot && !slots.includes(e.slot)) slots.push(e.slot);
            });
            let algumEquip = false;
            slots.forEach(slot => {
                const item = eqs.find(e => e.slot === slot);
                const li = document.createElement('li');
                li.style.minHeight = '24px';
                li.style.display = 'flex';
                li.style.alignItems = 'center';
                if (item) {
                    algumEquip = true;
                    li.textContent = `${item.emoji ? item.emoji + ' ' : ''}${item.nome}`;
                    if (item.atributos && typeof item.atributos === 'object' && Object.keys(item.atributos).length > 0) {
                        const span = document.createElement('span');
                        span.style.color = '#888';
                        span.style.marginLeft = '6px';
                        span.textContent = ' [' + Object.entries(item.atributos).map(([k, v]) => `${k.charAt(0).toUpperCase() + k.slice(1)}: ${v}`).join(', ') + ']';
                        li.appendChild(span);
                    }
                } else {
                    li.innerHTML = `<span style='color:#bbb;'>${slot.charAt(0).toUpperCase() + slot.slice(1)} vazio</span>`;
                }
                ul.appendChild(li);
            });
            if (!algumEquip) {
                ul.innerHTML = '<li style="color:#bbb;">Nenhum equipamento</li>';
            }
        }
        function renderInventario() {
            const ul = document.getElementById('inventario-list');
            ul.innerHTML = '';
            const inv = getInventario();
            // Descobrir todos os tipos presentes
            const tipos = [];
            inv.forEach(item => {
                if (item.tipo && !tipos.includes(item.tipo)) tipos.push(item.tipo);
            });
            if (inv.length === 0) {
                ul.innerHTML = '<li style="color:#bbb;">Nenhum item</li>';
            } else {
                tipos.forEach(tipo => {
                    const header = document.createElement('li');
                    header.innerHTML = `<b style='color:#444;'>${tipo.charAt(0).toUpperCase() + tipo.slice(1)}</b>`;
                    ul.appendChild(header);
                    inv.filter(item => item.tipo === tipo).forEach(item => {
                        const li = document.createElement('li');
                        let nome = '[Sem nome]';
                        if (typeof item.nome === 'string') {
                            nome = item.nome;
                        } else if (typeof item.nome === 'object' && item.nome !== null) {
                            nome = JSON.stringify(item.nome);
                        }
                        li.textContent = `${item.emoji ? item.emoji + ' ' : ''}${nome}`;
                        if (item.atributos && typeof item.atributos === 'object' && Object.keys(item.atributos).length > 0) {
                            const span = document.createElement('span');
                            span.style.color = '#888';
                            span.textContent = ' [' + Object.entries(item.atributos).map(([k, v]) => `${k.charAt(0).toUpperCase() + k.slice(1)}: ${v}`).join(', ') + ']';
                            li.appendChild(span);
                        }
                        ul.appendChild(li);
                    });
                });
            }
        }

        // Inicializar listas se não existirem
        if (!localStorage.getItem('rpg_equipamentos')) setEquipamentos([]);
        if (!localStorage.getItem('rpg_inventario')) setInventario([]);

        renderEquipamentos();
        renderInventario();
        // Carregar dados dinâmicos dos arquivos JSON
        let racesData = [];
        let classesData = [];
        let etapas = [];

        async function carregarDadosJogo() {
            const racesResp = await fetch('/data/races.json');
            racesData = await racesResp.json();
            window.racesData = racesData;
            const classesResp = await fetch('/data/classes.json');
            classesData = await classesResp.json();
            window.classesData = classesData;
            const starterPackResp = await fetch('/data/starterpack.json');
            const starterPackData = await starterPackResp.json();
            window.starterPackData = starterPackData;
            // Carregar base de itens
            const itensResp = await fetch('/data/itens.json');
            const itensData = await itensResp.json();
            window.itensData = itensData;

            // Etapas iniciais
            etapas = [
                {
                    nome: 'raca',
                    titulo: 'Sorteie a raça do seu personagem',
                    opcoes: racesData.map(r => r.nome),
                    chave: 'rpg_raca',
                    mensagem: 'Raça selecionada: ',
                    detalhes: (nome) => {
                        const r = racesData.find(x => x.nome === nome);
                        if (!r) return '';
                        let html = '';
                        if (r.aumento_valor_habilidade) html += `<div><b>Bônus:</b> ${r.aumento_valor_habilidade}</div>`;
                        if (r.caracteristicas_raciais) html += `<div><b>Características:</b> ${r.caracteristicas_raciais.join(', ')}</div>`;
                        if (r.subracas) html += `<div><b>Sub-raças:</b> ${r.subracas.map(s => `${s.nome} (${s.bonus})`).join(', ')}</div>`;
                        return html;
                    }
                },
                {
                    nome: 'classe',
                    titulo: 'Sorteie a classe do seu personagem',
                    opcoes: classesData.map(c => c.nome),
                    chave: 'rpg_classe',
                    mensagem: 'Classe selecionada: ',
                    detalhes: (nome) => {
                        const c = classesData.find(x => x.nome === nome);
                        if (!c) return '';
                        let html = '';
                        if (c.dado_vida) html += `<div><b>Dado de Vida:</b> ${c.dado_vida}</div>`;
                        if (c.habilidade_principal) html += `<div><b>Habilidade Principal:</b> ${c.habilidade_principal}</div>`;
                        if (c.salvaguardas) html += `<div><b>Salvaguardas:</b> ${c.salvaguardas.join(', ')}</div>`;
                        if (c.proficiencias_base) html += `<div><b>Proficiências:</b> ${c.proficiencias_base.join(', ')}</div>`;
                        return html;
                    }
                },
                {
                    nome: 'gameplay',
                    titulo: 'Encontro Aleatório!',
                    opcoes: [], // será preenchido dinamicamente
                    chave: null,
                    mensagem: 'Encontro: ',
                    detalhes: (nome) => ''
                },
                {
                    nome: 'teste',
                    titulo: 'Teste de Sorte',
                    opcoes: ["Sucesso Crítico", "Sucesso", "Falha", "Falha Crítica"],
                    chave: null,
                    mensagem: 'Resultado do teste: ',
                    detalhes: () => ''
                }
            ];

            // Carregar encontros
            const encountersResp = await fetch('/data/encounters.json');
            const encountersData = await encountersResp.json();
            window.encountersData = encountersData;
            // Preencher opções da etapa de gameplay com os nomes dos encontros
            if (etapas[2] && encountersData && Array.isArray(encountersData.encounters)) {
                etapas[2].opcoes = encountersData.encounters.map(e => e.nome);
            }

            // Função para atualizar as opções do starter pack conforme a classe escolhida
            const atualizarStarterPackOpcoes = () => {
                const classeEscolhida = localStorage.getItem('rpg_classe');
                if (!classeEscolhida) return;
                const classeKey = classeEscolhida.normalize('NFD').replace(/\p{Diacritic}/gu, '').toLowerCase();
                const pack = starterPackData.starter_packs[classeKey];
                if (!pack) {
                    etapas[2].opcoes = ['Starter pack não encontrado para esta classe'];
                } else if (pack.escolhas && pack.escolhas.length > 0) {
                    etapas[2].opcoes = pack.escolhas.map((escolha, idx) => `Escolha ${idx + 1}`);
                } else {
                    etapas[2].opcoes = ['Starter pack sem escolhas'];
                }
            };
            window.atualizarStarterPackOpcoes = atualizarStarterPackOpcoes;
        }

        const colors = ["#FF6384", "#36A2EB", "#FFCE56", "#4BC0C0", "#9966FF", "#FF9F40"];
        const canvas = document.getElementById('roleta-canvas');
        const ctx = canvas.getContext('2d');
        const size = canvas.width;
        const center = size / 2;
        const radius = center - 10;
        let anguloAtual = 0;
        let girando = false;
        let etapaAtual = 0;

        // Estado de vida do jogador        
        coracoes = getHP();
        
        function atualizarTitulo() {
            let titulo = etapas[etapaAtual].titulo;
            document.querySelector('h3').innerHTML = titulo;
        }

        // Se for roleta de sucesso/falha, desenhar fatias proporcionais
        function desenharRoleta(angulo = 0, opcoesCustom = null, fatiasCustom = null) {
            ctx.clearRect(0, 0, size, size);
            const opcoes = opcoesCustom || etapas[etapaAtual].opcoes;
            let fatias = [];
            if (fatiasCustom && fatiasCustom.length === opcoes.length) {
                fatias = fatiasCustom;
            } else {
                // Fatias iguais
                fatias = Array(opcoes.length).fill(1 / opcoes.length);
            }
            let anguloAtualSlice = angulo;
            for (let i = 0; i < opcoes.length; i++) {
                const slice = 2 * Math.PI * fatias[i];
                ctx.beginPath();
                ctx.moveTo(center, center);
                ctx.arc(center, center, radius, anguloAtualSlice, anguloAtualSlice + slice);
                ctx.closePath();
                ctx.fillStyle = colors[i % colors.length];
                ctx.fill();
                ctx.save();
                ctx.translate(center, center);
                ctx.rotate(anguloAtualSlice + slice / 2);
                ctx.textAlign = "right";
                ctx.fillStyle = "#222";
                // Ajuste dinâmico do tamanho da fonte
                let texto = opcoes[i];
                let baseFont = 18;
                let maxWidth = radius - 20;
                let fontSize = Math.max(12, Math.min(baseFont, Math.floor(maxWidth * 1.1 / (texto.length + 2))));
                if (opcoes.length > 8) fontSize = Math.max(10, fontSize - 2);
                ctx.font = `bold ${fontSize}px Arial`;
                let displayText = texto;
                while (ctx.measureText(displayText).width > maxWidth && displayText.length > 4) {
                    displayText = displayText.slice(0, -2) + '…';
                }
                ctx.fillText(displayText, radius - 10, 8);
                ctx.restore();
                anguloAtualSlice += slice;
            }
            // Desenhar ponteiro
            ctx.beginPath();
            ctx.moveTo(center, center - radius + 5);
            ctx.lineTo(center - 15, center - radius - 15);
            ctx.lineTo(center + 15, center - radius - 15);
            ctx.closePath();
            ctx.fillStyle = "#d32f2f";
            ctx.fill();
        }

        // Inicialização dinâmica após carregar dados
        async function inicializarJogo() {
            await carregarDadosJogo();
            atualizarTitulo();
            desenharRoleta();
        }

        inicializarJogo();

        const logList = [];
        function atualizarLog(resultado) {
            logList.unshift(resultado);
            const ul = document.getElementById('log-list');
            ul.innerHTML = '';
            logList.forEach((item) => {
                const li = document.createElement('li');
                li.textContent = item;
                ul.appendChild(li);
            });
        }

        // Controle para impedir múltiplas rolagens por etapa
        let etapaJaRolada = false;

        // --- NOVO FLUXO DE ENCONTROS ---
        // Estado para controlar se estamos sorteando o encontro ou interagindo com ele
        let aguardandoInteracaoEncontro = false;

        document.getElementById('girar-btn').onclick = async function() 
        {
            if (girando || etapaJaRolada) return;
            
            // Função de animação da roleta
            function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }
            function animarRoleta(anguloFinal, slices, callback) {
                let duracao = 1500 + (120 * slices);
                duracao = Math.max(2000, Math.min(4000, duracao));

                // Normaliza o ângulo final para garantir precisão
                anguloFinal = ((anguloFinal % (2 * Math.PI)) + (2 * Math.PI)) % (2 * Math.PI) + 2 * Math.PI * 4; // sempre 4 voltas completas
                const anguloInicial = anguloAtual % (2 * Math.PI);
                const start = performance.now();
                const audioTick = document.getElementById('audio-tick');
                let ultimoTick = 0;
                let tickInterval = Math.max(40, 180 - slices * 10);
                function playTick() {
                    if (audioTick) {
                        audioTick.currentTime = 0;
                        audioTick.play();
                    }
                }
                function anim(now) {
                    const elapsed = now - start;
                    let t = Math.min(1, elapsed / duracao);
                    t = easeOutCubic(t);
                    anguloAtual = anguloInicial + (anguloFinal - anguloInicial) * t;
                    desenharRoleta(anguloAtual);
                    if (elapsed - ultimoTick > tickInterval) {
                        playTick();
                        ultimoTick = elapsed;
                    }
                    if (elapsed < duracao) {
                        requestAnimationFrame(anim);
                    } else {
                        // Normaliza o ângulo final para sempre cair no centro da fatia
                        anguloAtual = anguloFinal % (2 * Math.PI);
                        desenharRoleta(anguloAtual);
                        if (callback) callback();
                    }
                }
                requestAnimationFrame(anim);
            }

            // Etapa de sorteio de encontro
            if (etapas[etapaAtual].nome === 'gameplay') {
                const lista = window.encountersData.encounters;
                const totalPeso = lista.reduce((acc, e) => acc + (e.probabilidade_peso || 1), 0);
                let r = Math.random() * totalPeso;
                let encontro = lista[0];
                for (let i = 0; i < lista.length; i++) {
                    r -= (lista[i].probabilidade_peso || 1);
                    if (r <= 0) { encontro = lista[i]; break; }
                }
                encontroAtual = encontro;
                // Sorteia o índice para animar a roleta
                const idx = lista.indexOf(encontro);
                const slices = lista.length;
                const anguloPorSlice = 2 * Math.PI / slices;
                const anguloAlvo = (idx + 0.5) * anguloPorSlice;
                const voltas = 5;
                const anguloFinal = (2 * Math.PI * voltas) + (1.5 * Math.PI) - anguloAlvo;
                girando = true;
                animarRoleta(anguloFinal, slices, function() {
                    girando = false;
                    atualizarLog('Encontro sorteado: ' + encontro.nome);
                    etapaJaRolada = true;
                    // Exibe popup do encontro
                    const popup = document.getElementById('popup-resultado');
                    const conteudo = document.getElementById('popup-resultado-conteudo');
                    let desc = (encontro.metadados && (encontro.metadados.narrativa_inicial || encontro.metadados.descricao)) || encontro.descricao || '';
                    conteudo.innerHTML = `<b>${encontro.nome}</b><br>${desc}`;
                    popup.style.display = 'flex';
                    atualizarTitulo();
                    desenharRoleta();
                });
                return;
            }

            // Etapa de teste de sorte/sucesso
            if (etapas[etapaAtual].nome === 'teste' && encontroAtual && etapas.findIndex(e => e.nome === 'teste') === etapaAtual) {
                // --- Lógica de sucesso baseada nos bônus do personagem ---
                // 1. Coletar requisitos do encontro
                let requisitos = [];
                let requisitosPesos = [];
                if (encontroAtual.logic_config) {
                    if (Array.isArray(encontroAtual.logic_config.teste_atributo)) {
                        encontroAtual.logic_config.teste_atributo.forEach(obj => {
                            requisitos.push(obj.nome);
                            requisitosPesos.push(obj.peso);
                        });
                    }
                    if (Array.isArray(encontroAtual.logic_config.teste_pericia)) {
                        encontroAtual.logic_config.teste_pericia.forEach(obj => {
                            requisitos.push(obj.nome);
                            requisitosPesos.push(obj.peso);
                        });
                    }
                }
                // 2. Calcular bônus total do personagem
                let bonusTotal = 0;
                let atributos = {};
                listaAtributos.forEach(attr => atributos[attr] = 0);
                if (starterAttrData && starterAttrData.templates_raciais) {
                    const raca = localStorage.getItem('rpg_raca');
                    const found = starterAttrData.templates_raciais.find(t => t.raca === raca);
                    if (found && found.atributos) {
                        for (const [attr, val] of Object.entries(found.atributos)) {
                            const key = attr.toLowerCase();
                            if (listaAtributos.includes(key)) atributos[key] += val;
                        }
                    }
                }
                if (window.classesData) {
                    const classe = localStorage.getItem('rpg_classe');
                    const found = window.classesData.find(c => c.nome === classe);
                    if (found && found.atributos) {
                        for (const [attr, val] of Object.entries(found.atributos)) {
                            const key = attr.toLowerCase();
                            if (listaAtributos.includes(key)) atributos[key] += val;
                        }
                    }
                }
                const inv = getInventario();
                inv.forEach(item => {
                    if (item.atributos) {
                        for (const [attr, val] of Object.entries(item.atributos)) {
                            const key = attr.toLowerCase();
                            if (listaAtributos.includes(key)) atributos[key] += val;
                        }
                    }
                });
                const eqs = getEquipamentos();
                eqs.forEach(item => {
                    if (item.atributos) {
                        for (const [attr, val] of Object.entries(item.atributos)) {
                            const key = attr.toLowerCase();
                            if (listaAtributos.includes(key)) atributos[key] += val;
                        }
                    }
                });
                let pericias = {};
                if (window.skillsData) {
                    window.skillsData.forEach(skill => { pericias[skill.nome] = 0; });
                }
                if (window.starterSkillsData && window.starterSkillsData.pericias_iniciais) {
                    const raca = localStorage.getItem('rpg_raca');
                    const classe = localStorage.getItem('rpg_classe');
                    const foundRace = window.starterSkillsData.pericias_iniciais.races.find(r => r.nome === raca);
                    if (foundRace && foundRace.skills) {
                        for (const [nome, val] of Object.entries(foundRace.skills)) {
                            pericias[nome] = (pericias[nome] || 0) + val;
                        }
                    }
                    const foundClass = window.starterSkillsData.pericias_iniciais.classes.find(c => c.nome === classe);
                    if (foundClass && foundClass.skills) {
                        for (const [nome, val] of Object.entries(foundClass.skills)) {
                            pericias[nome] = (pericias[nome] || 0) + val;
                        }
                    }
                }
                let itensBonus = 0;
                inv.concat(eqs).forEach(item => {
                    if (!item) return;
                    // Garante que todos os requisitos são strings
                    const requisitosStr = requisitos.map(r => typeof r === 'string' ? r : (r && r.nome ? r.nome : ''));
                    if (item.nome && requisitosStr.some(r => r.toLowerCase() === String(item.nome).toLowerCase())) itensBonus++;
                    if (item.tipo && requisitosStr.some(r => r.toLowerCase() === String(item.tipo).toLowerCase())) itensBonus++;
                });
                // Cálculo ponderado dos bônus
                bonusTotal = 0;
                let pesoTotal = requisitosPesos.reduce((a, b) => a + b, 0) || 100;
                for (let i = 0; i < requisitos.length; i++) {
                    const req = requisitos[i];
                    const peso = requisitosPesos[i] || 0;
                    const nomeReq = typeof req === 'string' ? req : (req && req.nome ? req.nome : '');
                    const key = nomeReq.toLowerCase();
                    let bonus = 0;
                    if (atributos[key]) bonus += atributos[key];
                    if (pericias[nomeReq]) bonus += pericias[nomeReq];
                    bonusTotal += bonus * (peso / pesoTotal);
                }
                bonusTotal += itensBonus;
                let chance = 0.5 + 0.1 * bonusTotal;
                chance = Math.min(0.95, Math.max(0.05, chance));

                // --- Roleta visual de sucesso/falha/crítico ---
                // Fatias: Sucesso Crítico (5%), Sucesso, Falha, Falha Crítica (5%)
                const critico = 0.05;
                const restante = 0.90;
                let chanceSucesso = chance * restante;
                let chanceFalha = (1 - chance) * restante;
                const fatiasSucesso = [critico, chanceSucesso, chanceFalha, critico];
                const opcoesSucesso = ["Sucesso Crítico", "Sucesso", "Falha", "Falha Crítica"];

                // Sorteio visual: determina qual fatia será sorteada
                let r = Math.random();
                let acumulado = 0;
                let sorteadoIdx = 0;
                for (let i = 0; i < fatiasSucesso.length; i++) {
                    acumulado += fatiasSucesso[i];
                    if (r < acumulado) {
                        sorteadoIdx = i;
                        break;
                    }
                }
                // Cálculo do ângulo
                const anguloAlvo = (fatiasSucesso.slice(0, sorteadoIdx).reduce((a, b) => a + b, 0) + fatiasSucesso[sorteadoIdx] / 2) * 2 * Math.PI;
                const voltas = 4;
                const anguloFinalSucesso = (2 * Math.PI * voltas) + (1.5 * Math.PI) - anguloAlvo;
                girando = true;
                
                animarRoletaSucesso(anguloFinalSucesso, opcoesSucesso, fatiasSucesso, sorteadoIdx, chance, encontroAtual, function() {
                    girando = false;
                    const popup = document.getElementById('popup-resultado');
                    const conteudo = document.getElementById('popup-resultado-conteudo');
                    let meta = encontroAtual.metadados || {};
                    let falhou = (sorteadoIdx === 2 || sorteadoIdx === 3);
                    let falhaCritica = (sorteadoIdx === 3);
                    let sucessoCritico = (sorteadoIdx === 0);
                    let falhaMsg = '';
                    let logMsg = '';
                    let nomeEncontro = encontroAtual.nome || 'Encontro';
                    // --- Consequências de SUCESSO ---
                    let recompensasAplicadas = [];
                    if ((sucessoCritico || sorteadoIdx === 1) && encontroAtual.logic_config && Array.isArray(encontroAtual.logic_config.recompensas)) {
                        let recompensas = encontroAtual.logic_config.recompensas;
                        let multiplicador = (sucessoCritico ? 2 : 1);
                        let inventarioModificado = false;
                        recompensas.forEach(recomp => {
                            // Exemplo: ouro
                            if (recomp.tipo === 'ouro' && recomp.valor) {
                                let qtd = Number(recomp.valor) * multiplicador;
                                let inventario = getInventario();
                                console.log(inventario);
                                let ouro = inventario.find(i => i.tipo === 'ouro');
                                console.log(ouro);
                                if (!ouro) {
                                    ouro = { tipo: 'ouro', nome: 'Ouro', quantidade: 0 };
                                    ouro.quantidade = (ouro.quantidade || 0) + qtd;
                                    inventario.push(ouro);
                                }
                                console.log(ouro);
                                setInventario(inventario);
                                recompensasAplicadas.push(`+${qtd} ouro`);
                                inventarioModificado = true;
                            }
                            // Exemplo: item
                            if (recomp.tipo === 'item' && recomp.item) {
                                let qtd = Number(recomp.quantidade || 1) * multiplicador;
                                let inventario = getInventario();
                                for (let i = 0; i < qtd; i++) {
                                    inventario.push(recomp.item);
                                }
                                setInventario(inventario);
                                recompensasAplicadas.push(`+${qtd}x ${recomp.item.nome || 'item'}`);
                                inventarioModificado = true;
                            }
                        });
                        if (inventarioModificado) {
                            renderInventario();
                        }
                    }
                    // Mensagem de sucesso
                    if (sucessoCritico) {
                        conteudo.innerHTML = `<b>Sucesso Crítico!</b><br>${meta.sucesso_critico_narrativa || 'Você teve um sucesso extraordinário!'}`;
                        logMsg = `Teste: Sucesso Crítico em ${nomeEncontro}!`;
                    } else if (sorteadoIdx === 1) {
                        conteudo.innerHTML = `<b>Sucesso!</b><br>${meta.sucesso_narrativa || 'Você superou o desafio.'}`;
                        logMsg = `Teste: Sucesso em ${nomeEncontro}.`;
                    }
                    if (recompensasAplicadas.length > 0) {
                        conteudo.innerHTML += `<div style='color:#388e3c;font-size:1em;margin-top:8px;'>${recompensasAplicadas.join(', ')}</div>`;
                        logMsg += `(${recompensasAplicadas.join(', ')})`;
                    }
                    // --- Consequências de FALHA ---
                    if (falhou && encontroAtual.logic_config && encontroAtual.logic_config.falha_consequencia && Array.isArray(encontroAtual.logic_config.falha_consequencia.efeitos)) {
                        let efeitos = encontroAtual.logic_config.falha_consequencia.efeitos;
                        let danoTotal = 0;
                        efeitos.forEach(ef => {
                            if (ef.tipo === 'dano' && ef.valor) {
                                danoTotal += Number(ef.valor);
                            }
                        });
                        if (falhaCritica) {
                            danoTotal *= 2;
                        }
                        if (danoTotal > 0) {
                            let hpAtual = getHP();
                            let novoHP = Math.max(0, hpAtual - danoTotal);
                            setHP(novoHP);
                            coracoes = novoHP;
                            conteudo.innerHTML += `Você perdeu ${danoTotal} ponto(s) de vida!`;
                            logMsg += ` (- ${danoTotal} vida)`;
                            if (novoHP <= 0) {
                                conteudo.innerHTML += `Você morreu! Fim de jogo.`;
                                logMsg += ` Morreu!`;
                            }
                        }
                    }
                    conteudo.innerHTML += `<div style='color:#888;font-size:0.9em;margin-top:8px;'>(Chance de sucesso: ${(chance*100).toFixed(0)}%)</div>`;
                    atualizarLog(logMsg);
                    popup.style.display = 'flex';
                    aguardandoInteracaoEncontro = false;
                    etapaJaRolada = true;
                    // Após sortear sucesso/falha, volta botão para 'Girar'
                    const btn = document.getElementById('girar-btn');
                    if (btn) btn.textContent = 'Girar';
                });
                return;
            }

            // Fluxo padrão para as outras etapas (raça, classe, etc)
            girando = true;

            const opcoes = etapas[etapaAtual].opcoes;
            const sorteadoIdx = Math.floor(Math.random() * opcoes.length);
            const sorteado = opcoes[sorteadoIdx];
            const slices = opcoes.length;
            const anguloPorSlice = 2 * Math.PI / slices;
            const anguloAlvo = (sorteadoIdx + 0.5) * anguloPorSlice;
            const voltas = 5;
            const anguloFinal = (2 * Math.PI * voltas) + (1.5 * Math.PI) - anguloAlvo;
            let atributos = {};

            animarRoleta(anguloFinal, slices, function() {
                let requisitos = [];
                let requisitosPesos = [];
                let itensBonus = 0; // Correção: declaração da variável antes do uso
                girando = false;

                if (etapas[etapaAtual].chave) {
                    localStorage.setItem(etapas[etapaAtual].chave, sorteado);
                }

                atualizarLog(etapas[etapaAtual].mensagem + sorteado);

                // Ao sortear raça ou classe, não avança etapa automaticamente!
                if (etapas[etapaAtual].nome === 'classe') {
                    const classeEscolhida = sorteado;
                    const starterPackData = window.starterPackData;
                    const itensData = window.itensData;
                    if (starterPackData && starterPackData.starter_packs && itensData && Array.isArray(itensData.itens)) {
                        const classeKey = classeEscolhida.normalize('NFD').replace(/\p{Diacritic}/gu, '').toLowerCase();
                        const pack = starterPackData.starter_packs[classeKey];
                        if (pack) {
                            // Montar inventário e equipamentos a partir dos ids
                            const getItemById = (id) => itensData.itens.find(i => i.id === id);
                            const equipamentos = Array.isArray(pack.equipamentos) ? pack.equipamentos.map(getItemById).filter(Boolean) : [];
                            const inventario = Array.isArray(pack.inventario) ? pack.inventario.map(getItemById).filter(Boolean) : [];
                            setEquipamentos(equipamentos);
                            setInventario(inventario);
                            // Atualiza imediatamente as abas de inventário e equipamentos
                            document.querySelector('#equipamentos-list').innerHTML = '';
                            document.querySelector('#inventario-list').innerHTML = '';
                            renderEquipamentos();
                            renderInventario();
                        }
                    }
                }

                // Ao sortear raça ou classe, zera encontroAtual
                if (etapas[etapaAtual].nome === 'raca' || etapas[etapaAtual].nome === 'classe') {
                    encontroAtual = null;
                }

                const popup = document.getElementById('popup-resultado');
                const conteudo = document.getElementById('popup-resultado-conteudo');
                conteudo.innerHTML = `<b>${sorteado}</b><br>${etapas[etapaAtual].detalhes ? etapas[etapaAtual].detalhes(sorteado) : ''}`;
                popup.style.display = 'flex';
                etapaJaRolada = true;
                desenharRoleta(anguloFinal);

                bonusTotal = 0;
                let pesoTotal = requisitosPesos.reduce((a, b) => a + b, 0) || 100;
                for (let i = 0; i < requisitos.length; i++) {
                    const req = requisitos[i];
                    const peso = requisitosPesos[i] || 0;
                    const nomeReq = typeof req === 'string' ? req : (req && req.nome ? req.nome : '');
                    const key = nomeReq.toLowerCase();
                    let bonus = 0;
                    if (atributos[key]) bonus += atributos[key];
                    if (pericias[nomeReq]) bonus += pericias[nomeReq];
                    bonusTotal += bonus * (peso / pesoTotal);
                }
                bonusTotal += itensBonus;
                let chance = 0.5 + 0.1 * bonusTotal;
                chance = Math.min(0.95, Math.max(0.05, chance));

                // --- Roleta visual de sucesso/falha/crítico ---
                // Fatias: Sucesso Crítico (5%), Sucesso, Falha, Falha Crítica (5%)
                const critico = 0.05;
                const restante = 0.90;
                let chanceSucesso = chance * restante;
                let chanceFalha = (1 - chance) * restante;
                const fatiasSucesso = [critico, chanceSucesso, chanceFalha, critico];
                const opcoesSucesso = ["Sucesso Crítico", "Sucesso", "Falha", "Falha Crítica"];

                // Sorteio visual: determina qual fatia será sorteada
                let r = Math.random();
                let acumulado = 0;
                let sorteadoIdx = 0;
                for (let i = 0; i < fatiasSucesso.length; i++) {
                    acumulado += fatiasSucesso[i];
                    if (r < acumulado) {
                        sorteadoIdx = i;
                        break;
                    }
                }

                // Cálculo do ângulo
                const anguloAlvo = (fatiasSucesso.slice(0, sorteadoIdx).reduce((a, b) => a + b, 0) + fatiasSucesso[sorteadoIdx] / 2) * 2 * Math.PI;
                const voltas = 4;
                const anguloFinalSucesso = (2 * Math.PI * voltas) + (1.5 * Math.PI) - anguloAlvo;
                girando = true;

                function animarRoletaSucesso(anguloFinal, callback) {

                    if(!encontroAtual){
                        girando = false;
                        return;
                    }

                    let duracao = 4200; // Mais dramático!
                    const anguloInicial = anguloAtual;
                    const start = performance.now();
                    const audioTick = document.getElementById('audio-tick');
                    let ultimoTick = 0;
                    let tickInterval = 120;
                    function playTick() {
                        if (audioTick) {
                            audioTick.currentTime = 0;
                            audioTick.play();
                        }
                    }
                    function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }
                    function anim(now) {
                        const elapsed = now - start;
                        let t = Math.min(1, elapsed / duracao);
                        t = easeOutCubic(t);
                        anguloAtual = anguloInicial + (anguloFinal - anguloInicial) * t;
                        desenharRoleta(anguloAtual, opcoesSucesso, fatiasSucesso);
                        if (elapsed - ultimoTick > tickInterval) {
                            playTick();
                            ultimoTick = elapsed;
                        }
                        if (elapsed < duracao) {
                            requestAnimationFrame(anim);
                        } else {
                            anguloAtual = anguloFinal;
                            desenharRoleta(anguloFinal, opcoesSucesso, fatiasSucesso);
                            if (callback) callback();
                        }
                    }
                    requestAnimationFrame(anim);
                }
                
                animarRoletaSucesso(anguloFinalSucesso, function() {
                    girando = false;

                    const popup = document.getElementById('popup-resultado');
                    const conteudo = document.getElementById('popup-resultado-conteudo');
                    let meta = encontroAtual.metadados || {};
                    
                    let falhou = (sorteadoIdx === 2 || sorteadoIdx === 3);
                    let falhaCritica = (sorteadoIdx === 3);
                    let sucessoCritico = (sorteadoIdx === 0);
                    let falhaMsg = '';

                    if (sucessoCritico) {
                        conteudo.innerHTML = `<b>Sucesso Crítico!</b><br>${meta.sucesso_critico_narrativa || 'Você teve um sucesso extraordinário!'}`;
                    } else if (sorteadoIdx === 1) {
                        conteudo.innerHTML = `<b>Sucesso!</b><br>${meta.sucesso_narrativa || 'Você superou o desafio.'}`;
                    } else if (sorteadoIdx === 2) {
                        falhaMsg = (encontroAtual.logic_config && encontroAtual.logic_config.falha_consequencia && encontroAtual.logic_config.falha_consequencia.narrativa) || 'Você sofreu as consequências.';
                        conteudo.innerHTML = `<b>Falha!</b><br>${falhaMsg}`;
                    } else {
                        falhaMsg = (encontroAtual.logic_config && encontroAtual.logic_config.falha_critica_narrativa) || 'Você sofreu uma falha desastrosa!';
                        conteudo.innerHTML = `<b>Falha Crítica!</b><br>${falhaMsg}`;
                    }

                    // Aplica efeitos de falha_consequencia (dano), dobrando em falha crítica
                    if (falhou && encontroAtual.logic_config && encontroAtual.logic_config.falha_consequencia && Array.isArray(encontroAtual.logic_config.falha_consequencia.efeitos)) {
                        let efeitos = encontroAtual.logic_config.falha_consequencia.efeitos;
                        let danoTotal = 0;
                        efeitos.forEach(ef => {
                            if (ef.tipo === 'dano' && ef.valor) {
                                danoTotal += Number(ef.valor);
                            }
                        });
                        if (falhaCritica) {
                            danoTotal *= 2;
                        }
                        if (danoTotal > 0) {
                            let hpAtual = getHP();
                            let novoHP = Math.max(0, hpAtual - danoTotal);
                            setHP(novoHP);
                            coracoes = novoHP;
                            conteudo.innerHTML += `<div style='color:#d32f2f;font-size:1em;margin-top:8px;'>Você perdeu ${danoTotal} ponto(s) de vida!</div>`;
                            if (novoHP <= 0) {
                                conteudo.innerHTML += `<div style='color:#d32f2f;font-size:1.2em;margin-top:8px;'><b>Você morreu! Fim de jogo.</b></div>`;
                            }
                        }
                    }

                    // Aplica recompensas em dobro no sucesso crítico
                    if (sucessoCritico && encontroAtual.logic_config && Array.isArray(encontroAtual.logic_config.recompensas)) {
                        let recompensas = encontroAtual.logic_config.recompensas;
                        // Exemplo: só exibe mensagem, lógica de adicionar ouro/item pode ser expandida
                        conteudo.innerHTML += `<div style='color:#388e3c;font-size:1em;margin-top:8px;'>Recompensa em dobro!</div>`;
                    }

                    conteudo.innerHTML += `<div style='color:#888;font-size:0.9em;margin-top:8px;'>(Chance de sucesso: ${(chance*100).toFixed(0)}%)</div>`;
                    popup.style.display = 'flex';
                    aguardandoInteracaoEncontro = false;
                    etapaJaRolada = true;
                    // Após sortear sucesso/falha, volta botão para 'Girar'
                    const btn = document.getElementById('girar-btn');
                    if (btn) btn.textContent = 'Girar';
                });
                //return;
            });
        }
        
        // Avançar etapa ao fechar popup
        document.getElementById('fechar-popup-btn').onclick = function() {
            const popup = document.getElementById('popup-resultado');
            popup.style.display = 'none';

            // Sempre resetar etapaJaRolada ao avançar etapa
            etapaJaRolada = false;

            // Etapa 1: raça → classe
            if (etapas[etapaAtual].nome === 'raca') {
                etapaAtual = etapas.findIndex(e => e.nome === 'classe');
                atualizarTitulo();
                desenharRoleta();
                document.getElementById('proximo-btn').style.display = 'none';
                return;
            }

            // Etapa 2: classe → gameplay
            if (etapas[etapaAtual].nome === 'classe') {
                etapaAtual = etapas.findIndex(e => e.nome === 'gameplay');
                atualizarTitulo();
                desenharRoleta();
                document.getElementById('proximo-btn').style.display = 'none';
                return;
            }

            // Etapa 3: gameplay → teste (apenas se vier diretamente da etapa gameplay)
            if (etapas[etapaAtual].nome === 'gameplay' && encontroAtual) {
                etapaAtual = etapas.findIndex(e => e.nome === 'teste');
                atualizarTitulo();
                desenharRoleta();
                return;
            }

            // Etapa 4: teste → gameplay (loop até morrer)
            if (etapas[etapaAtual].nome === 'teste') {
                if (coracoes <= 0) {
                    // Fim de jogo
                    document.getElementById('resultado').innerHTML = `<span style='color:#d32f2f;font-size:1.3em;'><b>Você morreu! Fim de jogo.</b></span>`;
                    return;
                }
                // Verifica o resultado do último teste para XP
                let popup = document.getElementById('popup-resultado-conteudo');
                let texto = popup ? popup.innerHTML : '';
                let ganhouXP = 0;
                if (texto.includes('Sucesso Crítico')) {
                    ganhouXP = 50;
                } else if (texto.includes('Sucesso')) {
                    ganhouXP = 25;
                }
                if (ganhouXP > 0) {
                    addXP(ganhouXP);
                    atualizarLog(`Você ganhou ${ganhouXP} pontos de experiência!`);
                    renderFicha();
                }
                // Limpa o encontroAtual para evitar reentrada indevida na etapa teste
                encontroAtual = null;
                etapaAtual = etapas.findIndex(e => e.nome === 'gameplay');
                atualizarTitulo();
                desenharRoleta();
                return;
            }
        };

        // (Função sortearEncontroAleatorio removida - lógica agora está no fluxo principal)

        // Resetar controle ao novo jogo
        const oldNovoJogoBtn = document.getElementById('novo-jogo-btn').onclick;
        document.getElementById('novo-jogo-btn').onclick = function() {
            etapaJaRolada = false;
            if (typeof oldNovoJogoBtn === 'function') oldNovoJogoBtn();
        };

        document.getElementById('proximo-btn').onclick = function() {
            if (etapaAtual < etapas.length - 1) {
                etapaAtual++;
                anguloAtual = 0;
                // Se for a etapa do starter pack, atualizar as opções
                if (etapas[etapaAtual].nome === 'starterpack') {
                    if (window.atualizarStarterPackOpcoes) window.atualizarStarterPackOpcoes();
                }
                atualizarTitulo();
                desenharRoleta();
                document.getElementById('resultado').innerText = 'Gire a roleta para sortear!';
                document.getElementById('proximo-btn').style.display = 'none';
            }
        };
        
    </script>
}